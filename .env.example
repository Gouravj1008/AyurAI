# ==================== SECURITY & KEYS ====================
# IMPORTANT: Keep these keys private! Never commit .env to version control
# Get Porcupine key from: https://picovoice.ai/console/
PORCUPINE_ACCESS_KEY=your_porcupine_key_here

# HuggingFace token for private models (optional)
HUGGINGFACE_TOKEN=your_hf_token_here

# ==================== MODEL CONFIGURATION ====================
# Base model to use
# Options: TinyLlama/TinyLlama-1.1B-Chat-v1.0, Meta-Llama-2-7b-chat, mistral, etc.
BASE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Path to LoRA adapter (Ayurveda-specific knowledge)
JARVIS_MEDICAL_ADAPTER=models/medical-lora

# Use GPU if available (true/false)
USE_GPU=true

# Model generation parameters
MODEL_TEMPERATURE=0.3
MODEL_MAX_TOKENS=256
MODEL_TOP_P=0.9

# ==================== AUDIO CONFIGURATION ====================
# Audio device index (-1 for auto-detect)
AUDIO_DEVICE_INDEX=-1

# Speech-to-text timeout in seconds
STT_TIMEOUT=10

# STT engine: vosk (offline) or other
STT_ENGINE=vosk

# ==================== HOTWORD CONFIGURATION ====================
# Path to Porcupine model file
HOTWORD_MODEL=models/porcupine/jarvis.ppn

# Enable hotword detection (true/false)
ENABLE_HOTWORD=true

# ==================== TTS CONFIGURATION ====================
# Enable text-to-speech (true/false)
ENABLE_TTS=true

# TTS engine: pyttsx3 (offline) or google (online)
TTS_ENGINE=pyttsx3

# ==================== TRAINING CONFIGURATION ====================
# Training parameters
TRAINING_BATCH_SIZE=2
TRAINING_EPOCHS=3
TRAINING_LR=2e-4
TRAINING_MAX_SEQ=512
TRAINING_LORA_R=16
TRAINING_LORA_ALPHA=32

# ==================== LOGGING ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=jarvis.log
